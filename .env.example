# -----------------------------------------------------------------------------
# YouTube Downloader - Environment Variables Example
# --------------------------------------------------------------------------
# Copy this file to .env and fill in with real values
# NEVER commit .env to version control
# --------------------------------------------------------------------------

# ============================================================================
# Application Settings
# ============================================================================
GO_ENV=development
LOG_LEVEL=debug
API_PORT=3000
ANALYTICS_API_PORT=3001

# ============================================================================
# PostgreSQL Database (Local)
# ============================================================================
POSTGRES_USER=ytd
POSTGRES_PASSWORD=ytd_password
POSTGRES_DB=ytd_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ytd:ytd_password@localhost:5432/ytd_db?sslmode=disable

# ============================================================================
# PostgreSQL Database (Neon Production)
# ============================================================================
# Copy exact connection string from Neon Dashboard
# DATABASE_URL=postgresql://neondb_owner:npg_pJAdZ7KrG9wR@ep-frosty-meadow-atufe5zb-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ============================================================================
# Redis (Local)
# ============================================================================
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ============================================================================
# Redis (Upstash Production)
# ============================================================================
# REDIS_URL=rediss://default:gQAAAAAAAhopAAIgcDJjY2I2MzZjMzFmMWE0NWVjOWU0MTEyYTRjNjVmN2M5YQ@useful-ladybug-137769.upstash.io:6379
# REDIS_HOST=useful-ladybug-137769.upstash.io
# REDIS_PORT=6379

# ============================================================================
# Redpanda / Kafka (Local)
# ============================================================================
REDPANDA_KAFKA_PORT=9092
REDPANDA_BROKERS=redpanda:9092

# ============================================================================
# Redpanda / Kafka (Production)
# ============================================================================
# REDPANDA_BROKERS=d9014nbl9b9vq71tbo4g.any.us-east-1.mpx.prd.cloud.redpanda.com:9092
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# ============================================================================
# MinIO (Local S3-compatible storage)
# ============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_VIDEOS=ytd-videos
MINIO_BUCKET_THUMBNAILS=ytd-thumbnails
MINIO_BUCKET_EXPORTS=ytd-exports

# ============================================================================
# Cloudflare R2 (Production S3-compatible storage)
# ============================================================================
AWS_REGION=auto
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_VIDEOS=ytd-videos
R2_BUCKET_THUMBNAILS=ytd-thumbnails
R2_BUCKET_EXPORTS=ytd-exports

# ============================================================================
# DuckDB (Analytics)
# ============================================================================
DUCKDB_DATABASE_URL=/duckdb/data/analytics.duckdb
MOTHERDUCK_TOKEN=

# ============================================================================
# Iceberg Catalog
# ============================================================================
ICEBERG_CATALOG=memory
# ICEBERG_CATALOG=s3
# ICEBERG_S3_PATH=s3://ytd-iceberg/catalog/

# ============================================================================
# Security
# ============================================================================
JWT_SECRET=local-dev-jwt-secret
API_KEY=your-dev-api-key

# ============================================================================
# YouTube / External APIs
# ============================================================================
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ============================================================================
# Cloudflare (Pages / Workers)
# ============================================================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ============================================================================
# Monitoring / Observability
# ============================================================================
SENTRY_DSN=
HONEYCOMB_API_KEY=
